# Copy this file to .env and fill in real values. Loaded via python-dotenv
# at the top of every entry point (api/main.py and each scripts/*.py), so
# `python scripts/route.py ...` and `uvicorn api.main:app` both pick it up
# without needing DATABASE_URL exported globally in your shell.

# Local PostgreSQL 18 + PostGIS. Create this role/db in pgAdmin first --
# see backend/README.md "Local setup" for the exact SQL.
DATABASE_URL=postgresql://transit:transit_dev_local@localhost:5432/transit

# console.anthropic.com/settings/keys -- used by ai/parse_query.py (intent
# extraction) and api/chat.py (post-route description refinement).
ANTHROPIC_API_KEY=
